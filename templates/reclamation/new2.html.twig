{% extends 'base.html.twig' %}

{% block title %}New Reclamation{% endblock %}

{% block body %}
    <style>
        /* Ensure the background color is consistent with the home page */
        #center {
            position: relative;
            padding: 100px 0; /* Increased padding for better spacing */
            text-align: center;
            border-radius: 15px; /* Slightly rounded corners */
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1); /* Soft shadow for depth */
        }

        .card {
            background-color: rgba(255, 255, 255, 0.9); /* More solid background */
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.81); /* Deeper shadow for professionalism */
            border-radius: 10px; /* Rounded corners */
            padding: 40px 30px;
            margin-top: 30px;
            z-index: 2; /* Ensure it's above the overlay */
        }

        /* Center the card vertically and horizontally over the image */
        .main_2 {
            position: relative;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: url('{{ asset('img/1.jpg') }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            filter: brightness(90%); /* Apply reduced brightness to the image */
        }

        /* Apply shadow effect to the image */
        .main_2::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.37); /* Dark overlay */
            z-index: 1; /* Make sure the overlay is below the form */
        }

        .container {
            max-width: 600px; /* Max width for the form */
            z-index: 2; /* Make sure the form is above the overlay */
        }

        /* Improved Typography */
        h2 {
            font-family: 'Roboto', sans-serif;
            color: #333;
            font-size: 30px;
            font-weight: 700;
        }

        .btn {
            font-weight: 500;
            border-radius: 25px;
            padding: 12px 30px;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }

        .btn-primary {
            background-color: #0066cc;
            border: none;
        }

        .btn-primary:hover {
            background-color: #005bb5;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background-color: #777;
            border: none;
        }

        .btn-secondary:hover {
            background-color: #666;
            transform: translateY(-2px);
        }

        /* Input Fields Styling */
        .form-control {
            font-size: 16px;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #ddd;
            transition: border-color 0.3s ease;
        }

        .form-control:focus {
            border-color: #0066cc;
            box-shadow: 0 0 5px rgba(0, 102, 204, 0.3);
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 8px;
            color: #555;
        }

        .text-center {
            text-align: center;
        }
    </style>

    <div class="main clearfix position-relative">
        <!-- Navbar Section -->
        <div class="main_1 clearfix position-absolute top-0 w-100">
            <section id="header">
                <nav class="navbar navbar-expand-md navbar-light" id="navbar_sticky">
                    <div class="container-xl">
                        <a class="navbar-brand p-0 fw-bold text-white" href="{{ path('app_home') }}">
                            <i class="fa fa-stethoscope me-1 col_blue"></i> BRIGHT <span class="fw-normal">Mind</span><br>
                            <span class="font_14 fw-normal span_1">Médecine Familiale</span>
                        </a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="navbarSupportedContent">
                            <ul class="navbar-nav mb-0 ms-auto">
                                <li class="nav-item"><a class="nav-link active" href="{{ path('app_home') }}">Accueil</a></li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">Services Médicaux</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" href="#">Course</a></li>
                                        <li><a class="dropdown-item" href="#">Course Detail</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_reclamation_new2') }}">
                                        Submit A Ticket <i class="fa fa-ticket ms-2"></i>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link link_icon rounded-circle" href="#"><i class="fa fa-user"></i></a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle link_icon rounded-circle" href="#" id="searchDropdown" role="button" data-bs-toggle="dropdown">
                                        <i class="fa fa-search"></i>
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <div class="input-group p-1">
                                                <input type="text" class="form-control" placeholder="Search Here">
                                                <button class="btn btn-primary">🔍</button>
                                            </div>
                                        </li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
            </section>
        </div>

        <!-- Background Image Section with Overlay -->
        <div class="main_2 clearfix position-relative">
            <section id="center" class="center_home">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <div class="carousel-caption d-md-block">
                            <!-- Optional: You can add a title or description here if needed -->
                        </div>
                    </div>
                </div>
            </section>

            <!-- Form Section: Centered over the image -->
            <div class="container mt-5 position-absolute top-50 start-50 translate-middle w-75">
                <div class="card shadow-lg p-4">
                    <h2 class="text-center mb-4">Submit a New Reclamation</h2>

                    {{ include('reclamation/_form2.html.twig', { 'button_label': 'Submit' }) }}

                    <div class="text-center mt-3">
                        <a href="{{ path('app_reclamation_index') }}" class="btn btn-secondary">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
